    "hono": "^4.6.0",
    "jose": "^6.2.2",
    "pdf-lib": "^1.17.1",
    "resend": "^6.10.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0",
    "wrangler": "^3.99.0"
  }
